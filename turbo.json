{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build:wasm": {
            "outputs": [
                "pkg/**"
            ],
            "cache": true
        },
        "build": {
            "dependsOn": [
                "^build",
                "build:wasm"
            ],
            "outputs": [
                "dist/**",
                "build/**"
            ],
            "cache": true
        },
        "dev": {
            "dependsOn": [
                "build:wasm"
            ],
            "cache": false,
            "persistent": true
        },
        "test": {
            "dependsOn": [
                "build"
            ],
            "cache": false
        },
        "lint": {
            "cache": true
        },
        "deploy": {
            "dependsOn": [
                "build"
            ],
            "cache": false
        }
    }
}